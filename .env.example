# PivotQuant runtime env template
# Copy to .env and fill values as needed.

# --- Model governance / promotion ---
# Runtime candidate manifest written by training (kept out of git)
RF_CANDIDATE_MANIFEST=manifest_runtime_latest.json
# Runtime metadata manifests (relative to RF_MODEL_DIR unless absolute path)
RF_METADATA_DIR=metadata_runtime
# Active manifest served by ml_server and used by reports
RF_ACTIVE_MANIFEST=manifest_active.json
# Optional hard override (absolute/relative path) for serving/reporting manifest
# RF_MANIFEST_PATH=data/models/manifest_active.json
# Governance gates
MODEL_GOV_REQUIRED_TARGETS=reject,break
MODEL_GOV_REQUIRED_HORIZONS=5,15,60
# Require at least 6h of new training coverage before promotion to active.
# This reduces candidate/version churn when retrain cycles run on near-identical data.
MODEL_GOV_MIN_TRAINED_END_DELTA_MS=21600000
MODEL_GOV_MAX_MFE_REGRESSION_BPS=1.5
MODEL_GOV_MAX_MAE_WORSENING_BPS=2.0
# Optional support thresholds for MAE/MFE regression gates.
# Gates are skipped for a target/horizon when support is below these floors.
# Keep 0 to disable support-aware skipping.
MODEL_GOV_MIN_TOTAL_SAMPLES=50
MODEL_GOV_MIN_POSITIVE_SAMPLES=20
# Optional per-target overrides (fall back to MODEL_GOV_MIN_POSITIVE_SAMPLES).
# MODEL_GOV_MIN_POSITIVE_SAMPLES_REJECT=20
# MODEL_GOV_MIN_POSITIVE_SAMPLES_BREAK=20
MODEL_GOV_ALLOW_FEATURE_VERSION_CHANGE=false
# Optional regime-aware MAE/MFE gate mode:
# - false: aggregate MAE/MFE gates only (default historical behavior)
# - true: allow aggregate regression waivers when supported regime buckets do not regress
MODEL_GOV_REGIME_AWARE=false
# Buckets evaluated when MODEL_GOV_REGIME_AWARE=true.
MODEL_GOV_REGIME_BUCKETS=compression,expansion,neutral
# Optional per-bucket support thresholds used by regime-aware checks.
MODEL_GOV_REGIME_MIN_TOTAL_SAMPLES=0
MODEL_GOV_REGIME_MIN_POSITIVE_SAMPLES=0
# Optional per-target overrides (fall back to MODEL_GOV_REGIME_MIN_POSITIVE_SAMPLES).
MODEL_GOV_REGIME_MIN_POSITIVE_SAMPLES_REJECT=0
MODEL_GOV_REGIME_MIN_POSITIVE_SAMPLES_BREAK=0
# Require at least this many supported buckets before waiving aggregate regressions.
MODEL_GOV_REGIME_MIN_COMPARED_BUCKETS=1
# Safety gate for threshold economics:
# reject promotion when candidate threshold utility guard is applied or score <= floor.
MODEL_GOV_ENFORCE_THRESHOLD_UTILITY_GUARD=true
# Targets included in threshold utility guard checks.
MODEL_GOV_THRESHOLD_UTILITY_TARGETS=reject
# Minimum acceptable threshold utility score.
MODEL_GOV_THRESHOLD_UTILITY_MIN_SCORE=0.0
# Emergency override: force promotion even if gates fail
MODEL_GOV_FORCE_PROMOTE=false

# ML scoring horizons treated as "shadow" (scored/reported but excluded from best_horizon signal selection).
ML_SHADOW_HORIZONS=30

# Event-analog shadow layer (nearest-neighbor historical context).
# This layer augments /score diagnostics only; it does not change signal decisions.
ML_ANALOG_ENABLED=true
# Optional override DB path (defaults to PREDICTION_LOG_DB / PIVOT_DB path).
# ML_ANALOG_DB=/Users/you/PIVOT_QUANT/data/pivot_events.sqlite
ML_ANALOG_K=20
ML_ANALOG_MAX_ROWS=250000
ML_ANALOG_MAX_CANDIDATES=1500
ML_ANALOG_MIN_POOL=30
ML_ANALOG_MIN_N=10
ML_ANALOG_MIN_EFFECTIVE_N=6
ML_ANALOG_MIN_FEATURES=3
ML_ANALOG_MIN_FEATURE_OVERLAP=3
ML_ANALOG_MIN_FEATURE_SUPPORT=20
# Optional fast prefilter before full analog distance scoring.
ML_ANALOG_PREFILTER_ENABLED=true
ML_ANALOG_PREFILTER_MAX_ROWS=600
ML_ANALOG_PREFILTER_FEATURE_LIMIT=4
ML_ANALOG_MAX_MEAN_DISTANCE=2.5
ML_ANALOG_MAX_CI_WIDTH=0.6
ML_ANALOG_RECENCY_TAU_DAYS=14
ML_ANALOG_RECENCY_FLOOR=0.25
# inv1p (default) uses 1/(1+distance) for smoother weighting.
# invdist uses 1/distance and is more peaky.
ML_ANALOG_SIM_WEIGHT_MODE=inv1p
# Shrink analog probabilities toward stage prior to improve calibration.
ML_ANALOG_PRIOR_STRENGTH=8
ML_ANALOG_DISAGREEMENT_FLAG=0.25
# Distance feature weights
ML_ANALOG_W_DISTANCE_BPS=1.0
ML_ANALOG_W_DISTANCE_ATR_RATIO=1.2
ML_ANALOG_W_VWAP_SIDE=0.5
ML_ANALOG_W_EMA_STACK=0.5
ML_ANALOG_W_RV_30=0.8
ML_ANALOG_W_OR_SIZE_ATR=0.7
ML_ANALOG_W_OVERNIGHT_GAP_ATR=0.6
# Disagreement threshold used for shadow diagnostics and guard logic.
ML_ANALOG_DISAGREEMENT_FLAG=0.25
# Disagreement guard:
# - off: disabled
# - shadow: log divergence if a high-disagreement horizon would be suppressed
# - active: force no_edge on configured high-disagreement horizons
ML_ANALOG_DISAGREEMENT_GUARD_MODE=shadow
# Comma-separated subset of 5,15,30,60
ML_ANALOG_DISAGREEMENT_GUARD_HORIZONS=15,30,60
# Blend controls (still gate-aware; active blend only when promotion gate is pass).
# off: disabled, shadow: compute blend shadow fields only, active: apply blended probs in /score
ML_ANALOG_BLEND_MODE=shadow
# Optional partial promotion scope when blend mode is active and global gate is fail:
# - off: require global gate pass (default, safest)
# - horizon: allow blend only for gate-passed horizons
# - target: allow blend per target using gate horizon_results reject_pass/break_pass flags
ML_ANALOG_BLEND_PARTIAL_MODE=off
ML_ANALOG_BLEND_WEIGHT_BASE=0.30
ML_ANALOG_BLEND_WEIGHT_MAX=0.60
ML_ANALOG_BLEND_N_EFF_REF=20
# Optional safety caps: limit absolute blend shift away from model probability.
# Keep at 1.0 to effectively disable caps.
ML_ANALOG_BLEND_MAX_SHIFT_REJECT=1.0
ML_ANALOG_BLEND_MAX_SHIFT_BREAK=1.0
# Optional per-horizon overrides (format: "5:0.10,15:0.08,30:0.06,60:0.06")
# ML_ANALOG_BLEND_MAX_SHIFT_REJECT_BY_HORIZON=5:0.10,15:0.08,30:0.06,60:0.06
# ML_ANALOG_BLEND_MAX_SHIFT_BREAK_BY_HORIZON=5:0.06,15:0.06,30:0.08,60:0.08
# Report-time promotion gate (for future analog blending enablement).
# Eval mode: analog=raw/shrunk analog probs, blend=model/analog blend probs.
ML_ANALOG_PROMOTION_EVAL_MODE=blend
# Rolling lookback window (days) used when evaluating promotion gate metrics.
ML_ANALOG_PROMOTION_LOOKBACK_DAYS=5
# Use shrinkage-adjusted analog probabilities when evaluating analog-only deltas.
ML_ANALOG_PROMOTION_USE_SHRUNK=true
ML_ANALOG_PROMOTION_MIN_AVAILABLE=50
ML_ANALOG_PROMOTION_MIN_QUALITY_OK=30
ML_ANALOG_PROMOTION_MIN_EFFECTIVE_N=8
ML_ANALOG_PROMOTION_MAX_MEAN_CI_WIDTH=0.35
ML_ANALOG_PROMOTION_MAX_BRIER_DELTA=0.0
ML_ANALOG_PROMOTION_MAX_ECE_DELTA=0.0
ML_ANALOG_PROMOTION_MIN_HORIZONS=2
ML_ANALOG_PROMOTION_REQUIRE_BOTH_TARGETS=true
# Optional: path consumed by /health for analog gate state.
# ML_ANALOG_PROMOTION_GATE_PATH=/Users/tristanalejandro/PIVOT_QUANT/logs/reports/analog_promotion_gate_latest.json

# Regime policy layer for threshold selection:
# - off: baseline thresholds only (legacy behavior)
# - shadow: compute regime policy and log divergences, but do not change live signals
# - active: apply regime-adjusted thresholds for compression/expansion buckets
ML_REGIME_POLICY_MODE=shadow
# Reject signal OR-breakout filter:
# - off: disabled (default, safest)
# - shadow: count/log reject signals that would be filtered
# - active: suppress matching reject signals to no_edge
ML_REJECT_OR_BREAKOUT_FILTER_MODE=off
# Comma-separated horizons (subset of 5,15,30,60) for this filter.
ML_REJECT_OR_BREAKOUT_FILTER_HORIZONS=15
# Comma-separated OR breakout values to block for reject signals.
ML_REJECT_OR_BREAKOUT_FILTER_BLOCK_VALUES=-1
# Optional per-horizon rules (overrides HORIZONS/BLOCK_VALUES when set).
# Format: "<horizon>:<value>[|<value>],<horizon>:<value>" (e.g. "15:-1,60:0")
ML_REJECT_OR_BREAKOUT_FILTER_RULES=
# Hard cap on any per-regime threshold shift (0.0-0.20).
ML_REGIME_THRESHOLD_MAX_DELTA=0.05
# Compression defaults: easier rejects, harder breaks.
ML_REGIME_COMPRESSION_REJECT_DELTA=-0.02
ML_REGIME_COMPRESSION_BREAK_DELTA=0.02
# Expansion defaults: harder rejects, easier breaks.
ML_REGIME_EXPANSION_REJECT_DELTA=0.02
ML_REGIME_EXPANSION_BREAK_DELTA=-0.02
# ATR-distance zones (distance_atr_ratio) used as an overlay on top of regime thresholds.
# Zones: ultra < ULTRA_MAX, near < NEAR_MAX, mid < MID_MAX, far >= MID_MAX.
ML_ATR_ZONE_ULTRA_MAX=0.05
ML_ATR_ZONE_NEAR_MAX=0.10
ML_ATR_ZONE_MID_MAX=0.20
# Compression + ATR overlays:
# - ultra: cautious on perfect touches (harder reject, easier break)
# - near: mild mean-reversion bias (easier reject, harder break)
ML_ATR_COMPRESSION_ULTRA_REJECT_DELTA=0.02
ML_ATR_COMPRESSION_ULTRA_BREAK_DELTA=-0.01
ML_ATR_COMPRESSION_NEAR_REJECT_DELTA=-0.01
ML_ATR_COMPRESSION_NEAR_BREAK_DELTA=0.01
# Expansion + ATR overlays:
# - ultra/near: continuation bias (harder reject, easier break)
ML_ATR_EXPANSION_ULTRA_REJECT_DELTA=0.03
ML_ATR_EXPANSION_ULTRA_BREAK_DELTA=-0.02
ML_ATR_EXPANSION_NEAR_REJECT_DELTA=0.01
ML_ATR_EXPANSION_NEAR_BREAK_DELTA=-0.01
# Feature drift alert tuning:
# - Min out-of-bound feature count before FEATURE_DRIFT_* flag is emitted.
ML_FEATURE_DRIFT_MIN_FEATURES=2
# Comma-separated features to exclude from drift checks (highly discrete/capped features can be noisy).
ML_FEATURE_DRIFT_IGNORE_COLUMNS=hist_sample_size,regime_type
# Temporary guardrail for expansion + near pocket:
# - off: disable
# - shadow: evaluate and log divergence only
# - active: apply guardrail policy to live signal selection
ML_REGIME_GUARD_EXPANSION_NEAR_MODE=shadow
# Guardrail policy:
# - no_trade: force no_edge (thresholds pinned to 0.99)
# - tighten: increase reject/break thresholds by configured deltas
ML_REGIME_GUARD_EXPANSION_NEAR_STRATEGY=no_trade
ML_REGIME_GUARD_EXPANSION_NEAR_REJECT_DELTA=0.03
ML_REGIME_GUARD_EXPANSION_NEAR_BREAK_DELTA=0.03

# Run lightweight ops smoke tests automatically before each retrain cycle.
# If tests fail, retrain aborts and sends immediate alert via ML_ALERT channels.
ML_RUN_OPS_SMOKE_ON_RETRAIN=true
# After retrain+reload, score any recent touch_events missing live predictions.
RETRAIN_SCORE_UNSCORED_ON_RETRAIN=true
RETRAIN_SCORE_UNSCORED_LOOKBACK_DAYS=7
RETRAIN_SCORE_UNSCORED_LIMIT=3000
RETRAIN_SCORE_UNSCORED_BATCH_SIZE=16
RETRAIN_SCORE_UNSCORED_TIMEOUT_SEC=20
RETRAIN_SCORE_UNSCORED_MAX_ATTEMPTS=3
RETRAIN_SCORE_UNSCORED_RETRY_BASE_SEC=0.5
RETRAIN_SCORE_UNSCORED_RETRY_MAX_SEC=5
# Verify post-retrain catch-up coverage and warn when backlog remains.
RETRAIN_SCORE_UNSCORED_VERIFY_ON_RETRAIN=true
RETRAIN_SCORE_UNSCORED_MAX_REMAINING=0
# When true, fail retrain score catch-up if any event failed even if backlog threshold passed.
RETRAIN_SCORE_UNSCORED_FAIL_ON_PARTIAL=false
# Refresh dashboard-facing ML metrics exports every retrain cycle.
RETRAIN_REFRESH_ML_METRICS_ON_RETRAIN=true
# Metrics refresh profile (defaults align with /api/ml/metrics contract expectations).
RETRAIN_METRICS_DUCKDB_PATH=data/pivot_training.duckdb
RETRAIN_METRICS_DUCKDB_VIEW=training_events_v1
RETRAIN_METRICS_TARGET=reject
RETRAIN_METRICS_HORIZON_MIN=15
RETRAIN_METRICS_TRAIN_DAYS=30
RETRAIN_METRICS_CALIB_DAYS=5
RETRAIN_METRICS_TEST_DAYS=5
RETRAIN_METRICS_MAX_FOLDS=12
RETRAIN_METRICS_MIN_EVENTS=200
RETRAIN_METRICS_SPLIT_MODE=rolling
RETRAIN_METRICS_OUT=data/exports/rf_walkforward_metrics.json
RETRAIN_METRICS_CALIB_OUT=data/exports/rf_calibration_curve.json
RETRAIN_METRICS_CALIB_CSV=data/exports/rf_calibration_curve.csv
RETRAIN_METRICS_FEATURE_OUT=data/exports/rf_feature_report.json
RETRAIN_METRICS_FEATURE_CSV=data/exports/rf_feature_report.csv
# Stack monitor: consecutive failed health cycles required before supervisor exits.
MONITOR_CONSECUTIVE_FAIL_LIMIT=3
# Weekly policy review: only count predictions scored near event time.
ML_WEEKLY_REVIEW_MAX_PRED_LAG_HOURS=6
# Prediction-row basis for reporting scripts:
# - first: first scored row per event (execution-fidelity view; recommended default)
# - latest: most recent scored row per event (replay/debug view)
ML_DAILY_REPORT_PREDICTION_BASIS=first
ML_WEEKEND_AUDIT_PREDICTION_BASIS=first

# --- Public dashboard sharing hardening (Tailscale Funnel / internet exposure) ---
# Enable password-only dashboard auth at the proxy (:3000).
# Recommended when exposing the host publicly.
DASH_AUTH_ENABLED=false
DASH_AUTH_PASSWORD=
# Password policy gate for dashboard auth strength.
# If password length is below DASH_AUTH_MIN_PASSWORD_LEN, proxy startup fails
# closed with a configuration error.
DASH_AUTH_ENFORCE_STRONG_PASSWORD=true
# Recommended minimum is a random 20+ character value.
DASH_AUTH_MIN_PASSWORD_LEN=20
# Brute-force throttling for /auth/login.
DASH_AUTH_RATE_LIMIT_ENABLED=true
DASH_AUTH_RATE_LIMIT_WINDOW_SEC=300
DASH_AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
DASH_AUTH_RATE_LIMIT_LOCKOUT_SEC=900
DASH_AUTH_RATE_LIMIT_MAX_TRACKED_CLIENTS=4096
# Login/session visibility window (counts shown in /health).
# Tracks active sessions and unique successful login clients in this window.
DASH_AUTH_METRICS_WINDOW_SEC=86400
DASH_AUTH_METRICS_MAX_TRACKED_CLIENTS=4096
# Optional login page text.
DASH_AUTH_PAGE_TITLE=PivotQuant Dashboard Access
DASH_AUTH_PAGE_SUBTITLE=Enter password to continue.
# Session cookie controls.
DASH_AUTH_COOKIE_NAME=pq_dash_auth
DASH_AUTH_COOKIE_TTL_SEC=2592000
# Apply Secure flag only on HTTPS requests when true.
DASH_AUTH_COOKIE_SECURE=true
# Allow localhost requests (launchd/scripts on host) without auth.
# Keep false for non-loopback HOST bindings (enforced by startup checks).
# If false and DASH_AUTH_ENABLED=true, local clients must send
# X-Pivot-Service-Token matching DASH_AUTH_SERVICE_TOKEN.
DASH_AUTH_LOCAL_BYPASS=false
# Optional machine-to-machine token for local API clients (backfill/live collector).
# When set, local API calls can authenticate via X-Pivot-Service-Token header
# without requiring dashboard login cookies.
DASH_AUTH_SERVICE_TOKEN=
# Restrict mutation endpoints (/api/bars,/api/events,/api/ml/score,/api/ml/reload)
# to local requests only. Keep true for public sharing.
DASH_WRITE_ENDPOINTS_LOCAL_ONLY=true
# Browser CORS allowlist used by local HTTP services (:5001/:5002/:5004) and ml_server.
ML_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Event writer DB durability controls.
EVENT_WRITER_SQLITE_SYNC=FULL
EVENT_WRITER_WAL_AUTOCHECKPOINT=1000
# Max events accepted per /api/ml/score batch request.
ML_SCORE_MAX_BATCH_EVENTS=256
# Concurrent /score requests accepted by ml_server before it returns 429 (busy).
ML_SCORE_MAX_IN_FLIGHT=2
# When in-flight score load reaches this value, skip analog scoring work for
# new requests so core model scoring latency stays bounded.
ML_SCORE_ANALOG_DISABLE_IN_FLIGHT=1
# Inference-time sklearn n_jobs override. Keep at 1 to avoid joblib worker
# spin-up overhead on single-event /score requests.
ML_INFERENCE_N_JOBS=1
# SQLite prediction_log connect timeout (seconds) for /score logging.
# Keep low to avoid score-path stalls under write lock contention.
PREDICTION_LOG_CONNECT_TIMEOUT_SEC=0.5
# SQLite busy timeout (milliseconds) for prediction_log writes.
PREDICTION_LOG_BUSY_TIMEOUT_MS=500
# Minimum interval (seconds) between WARNING logs for repeated SQLite contention.
PREDICTION_LOG_LOCK_WARN_INTERVAL_SEC=60
PREDICTION_LOG_SQLITE_SYNC=FULL
PREDICTION_LOG_WAL_AUTOCHECKPOINT=1000
# Max buffered prediction-log writes held in memory before new writes are
# dropped to protect score latency under sustained DB contention.
PREDICTION_LOG_QUEUE_MAX_SIZE=4096
# Alert thresholds surfaced in /health prediction_log_alerts.
PREDICTION_LOG_ALERT_QUEUE_DEPTH=512
PREDICTION_LOG_ALERT_DROPPED_TOTAL=0
PREDICTION_LOG_ALERT_WRITE_FAIL_TOTAL=0
# Minimum spacing between accepted /api/ml/reload calls (seconds).
# Extra calls return 429 (cooldown) to protect /score availability.
ML_RELOAD_MIN_INTERVAL_SEC=1.5
# Audit retention for ops_audit_events (days). Prune runs as contiguous
# prefix cleanup to preserve tamper-evident chain verification.
ML_AUDIT_RETENTION_DAYS=90
# Minimum interval between automatic audit prune runs (milliseconds).
# 86400000 = once per day.
ML_AUDIT_PRUNE_INTERVAL_MS=86400000

# --- Daily report notifications ---
# Comma-separated channels: email,imessage,webhook
ML_REPORT_NOTIFY_CHANNELS=email

# If true, retrain cycle (every 6h) sends notifications too.
# Keep false if using scheduled daily LaunchAgent to avoid spam.
ML_REPORT_NOTIFY_ON_RETRAIN=false
ML_REPORT_EMAIL_STYLE=compact
ML_REPORT_ANOMALY_LIMIT=6
# Auto-failover when email fails with Gmail auth/rate-limit errors (535/550)
ML_REPORT_FAILOVER_CHANNELS=webhook,imessage

# --- Immediate health alerts (ML / collector downtime) ---
# Default behavior: notify only on state transitions (DOWN, RECOVERED)
ML_ALERT_NOTIFY_CHANNELS=email
# Optional override recipient list (falls back to ML_REPORT_EMAIL_TO)
# ML_ALERT_EMAIL_TO=you@example.com
# Optional override sender (falls back to ML_REPORT_EMAIL_FROM)
# ML_ALERT_EMAIL_FROM=you@example.com
# Health endpoints to watch
ML_ALERT_ML_HEALTH_URL=http://127.0.0.1:5003/health
ML_ALERT_COLLECTOR_HEALTH_URL=http://127.0.0.1:5004/health
# LaunchAgent check frequency (seconds)
ML_ALERT_CHECK_INTERVAL_SEC=60
# Health request timeout per endpoint (seconds)
ML_ALERT_TIMEOUT_SEC=4
# Require this many consecutive failed health checks before marking a service DOWN.
# Helps suppress transient restart blips from triggering outage notifications.
ML_ALERT_CONSECUTIVE_FAILS=2
# ML scoring-latency regression guard (watchdog uses /health score.last_duration_ms)
# 0 disables this guard. Recommended: keep >= 2x your normal p95.
ML_ALERT_ML_SCORE_LAST_DURATION_MAX_MS=2000
# Ignore latency guard until enough successful score requests have accumulated.
ML_ALERT_ML_SCORE_MIN_SUCCESS_COUNT=5
# Require this many consecutive latency breaches before raising DOWN alert.
ML_ALERT_ML_SCORE_CONSECUTIVE_FAILS=3
# Intraday collector scoring-lag guard (unscored events in recent window)
ML_ALERT_COLLECTOR_UNSCORED_GUARD=true
# If unscored live events in lookback exceed this, streak advances.
ML_ALERT_COLLECTOR_UNSCORED_MAX=0
# Lookback window for unscored live events.
ML_ALERT_COLLECTOR_UNSCORED_LOOKBACK_MIN=120
# Require this many consecutive watchdog checks before alerting on scoring lag.
ML_ALERT_COLLECTOR_UNSCORED_CONSECUTIVE_FAILS=3
# If true, evaluate unscored guard only during regular market hours (ET weekdays 09:30-16:00).
ML_ALERT_COLLECTOR_UNSCORED_MARKET_HOURS_ONLY=true
# Re-alert while still down (minutes). 0 = disabled (transition-only alerts)
ML_ALERT_REPEAT_MIN=0
# Subject prefixes
ML_ALERT_SUBJECT_PREFIX=[ALERT]
ML_ALERT_RECOVERY_PREFIX=[RECOVERED]
# Auto-failover when email fails with Gmail auth/rate-limit errors (535/550)
ML_ALERT_FAILOVER_CHANNELS=webhook,imessage

# --- Session routine checks (scheduled ET pre-open + post-open snapshots) ---
# LaunchAgent loop cadence (seconds). The checker itself gates by ET windows.
ML_SESSION_ROUTINE_INTERVAL_SEC=300
# ET reference timezone for schedule windows
ML_SESSION_ET_TZ=America/New_York
# Target windows in ET
ML_SESSION_PREOPEN_HOUR=9
ML_SESSION_PREOPEN_MINUTE=20
ML_SESSION_POSTOPEN_HOUR=9
ML_SESSION_POSTOPEN_MINUTE=40
# Allow N-minute execution window after each target minute
ML_SESSION_WINDOW_MIN=10
# Send OK summaries as well (true = two daily routine updates)
ML_SESSION_NOTIFY_ON_OK=true
# Optional per-phase overrides
# ML_SESSION_PREOPEN_NOTIFY_ON_OK=true
# ML_SESSION_POSTOPEN_NOTIFY_ON_OK=true
# Post-open flow thresholds (lookback window)
ML_SESSION_LOOKBACK_MIN=15
ML_SESSION_POSTOPEN_MIN_BARS=1
ML_SESSION_POSTOPEN_MIN_EVENTS=0
ML_SESSION_POSTOPEN_MIN_LIVE_PREDS=0
# Optional endpoints
ML_SESSION_OPS_STATUS_URL=http://127.0.0.1:3000/api/ops/status
ML_SESSION_GAMMA_URL=http://127.0.0.1:5001/gamma?symbol=SPY&expiry=front&limit=10
# Subject prefix for non-failing routine checks
ML_SESSION_CHECK_PREFIX=[CHECK]

# Optional scheduled-delivery time overrides (Mac local time)
# ML_REPORT_MORNING_HOUR=8
# ML_REPORT_MORNING_MINUTE=5
# ML_REPORT_CLOSE_HOUR=17
# ML_REPORT_CLOSE_MINUTE=10
# Lock/dedupe controls for report sender
# ML_REPORT_LOCK_WAIT_SEC=120
# ML_REPORT_FORCE_SEND=false
# Optional report date override controls:
# ML_REPORT_REPORT_DATE=2026-02-17
# ML_REPORT_REPORT_DATE_MODE=auto
# Modes: auto | et_today | latest_completed

# Email (SMTP)
ML_REPORT_EMAIL_TO=you@example.com
ML_REPORT_EMAIL_FROM=you@example.com
ML_REPORT_SMTP_HOST=smtp.gmail.com
ML_REPORT_SMTP_PORT=587
ML_REPORT_SMTP_USER=you@example.com
ML_REPORT_SMTP_PASS=replace_with_app_password
ML_REPORT_SMTP_USE_TLS=true

# Include runtime log tails in email body.
ML_REPORT_INCLUDE_LOG_TAILS=true
ML_REPORT_LOG_TAIL_LINES=80
# Optional cost model for impact section (bps)
ML_COST_SPREAD_BPS=0.8
ML_COST_SLIPPAGE_BPS=0.4
ML_COST_COMMISSION_BPS=0.1
# Threshold tuning objective for retrain/calibration:
# utility_bps optimizes expected net bps (direction-aware, after costs).
# Set to f1 if you need a pure classification objective instead.
RF_THRESHOLD_OBJECTIVE=utility_bps
# Calibration window (event_date_et days) used for calibrator + threshold tuning.
# Wider windows reduce threshold churn and utility sign flips from tiny samples.
RF_CALIB_DAYS=10
# Institutional risk guard: disable thresholds when selected utility is non-positive.
RF_THRESHOLD_MIN_UTILITY_SCORE=0.0
RF_THRESHOLD_DISABLE_ON_NONPOSITIVE_UTILITY=true
# Disable fallback thresholds (e.g. default 0.5) unless explicitly overridden.
RF_THRESHOLD_DISABLE_ON_FALLBACK=true
# Optional per target/horizon threshold tuning overrides.
# Format: "<target>:<horizon>=<value>" entries separated by commas.
# The default below intentionally relaxes break threshold search for 15m/30m/60m
# while keeping 5m break untouched to avoid overfitting sparse positives.
RF_THRESHOLD_MIN_SIGNALS_OVERRIDES=break:15=8,break:30=8,break:60=6
# Optional per target/horizon precision floor overrides (blank = use global floor).
# Example: RF_THRESHOLD_PRECISION_FLOOR_OVERRIDES=break:15=0.35,break:60=0.30
RF_THRESHOLD_PRECISION_FLOOR_OVERRIDES=
# Threshold value used for no-trade guard (1.0 => practically no signals).
RF_THRESHOLD_NO_TRADE_THRESHOLD=1.0
CALIB_REFIT_THRESHOLD_OBJECTIVE=utility_bps
# During calibration refit retune, prefer threshold candidates above this utility floor.
CALIB_REFIT_THRESHOLD_MIN_UTILITY_SCORE=0.0
# Session-aware staleness thresholds (US regular session hours, ET)
# 13.0h ~= 2 sessions, 19.5h ~= 3 sessions
ML_STALENESS_WARN_SESSION_HOURS=13
ML_STALENESS_KILL_SESSION_HOURS=19.5
# Daily report horizons to render (must match prediction_log signal/prob columns).
ML_REPORT_HORIZONS=5,15,30,60
# Gamma enrichment for event generation (optional, IBKR bridge)
GAMMA_BRIDGE_URL=http://127.0.0.1:5001/gamma
# IBKR connect guard: fail fast when gateway is unavailable, then back off retries.
IB_CONNECT_TIMEOUT_SEC=5.0
IB_CONNECT_RETRY_BACKOFF_SEC=5.0
# marketdata.app API token — enables historical backfill >7d and gamma/IV fallback
# when IBKR options permissions are unavailable (Error 10089). Get at marketdata.app
MARKETDATA_APP_TOKEN=your_token_here
# Optional local Yahoo proxy endpoint used by backfill/live collector in source=yahoo mode.
# Set empty to always use direct Yahoo chart API.
YAHOO_PROXY_URL=http://127.0.0.1:3000/api/market
# Optional local service token forwarded as X-Pivot-Service-Token when calling YAHOO_PROXY_URL.
# If unset, falls back to DASH_AUTH_SERVICE_TOKEN when available.
YAHOO_PROXY_SERVICE_TOKEN=
# When dashboard auth is enabled and local bypass is disabled, skip proxy calls
# unless a service token is configured (avoids recurring 401 noise).
YAHOO_PROXY_SKIP_AUTH_REQUIRED=true
# If Yahoo proxy returns 401/403 (dashboard auth), bypass proxy for N seconds
# and use direct Yahoo API to avoid repeated auth-retry noise.
YAHOO_PROXY_AUTH_FAILOPEN_SEC=900
# Offline gamma history collection tuning (scripts/collect_gamma_history.py)
GAMMA_HISTORY_STRIKE_RANGE_PCT=0.2
GAMMA_HISTORY_MAX_STRIKES=120
GAMMA_HISTORY_HTTP_TIMEOUT_SEC=60
# Retry/backoff for provider throttling and transient failures.
GAMMA_HISTORY_HTTP_MAX_ATTEMPTS=6
GAMMA_HISTORY_HTTP_RETRY_BASE_SEC=1.0
GAMMA_HISTORY_HTTP_RETRY_MAX_SEC=30.0
GAMMA_HISTORY_HTTP_RETRY_JITTER_SEC=0.25
GAMMA_HISTORY_SQLITE_SYNC=FULL
GAMMA_HISTORY_WAL_AUTOCHECKPOINT=1000
# Optional Black-Scholes fallback when provider gamma is missing.
# Keeps provider gamma as primary source; computed gamma is used only for null gaps.
GAMMA_COMPUTE_FALLBACK=false
# If IV is missing, solve IV from option mid/last/close when possible.
GAMMA_COMPUTE_FALLBACK_SOLVE_IV=true
GAMMA_COMPUTE_FALLBACK_RISK_FREE_RATE=0.045
GAMMA_COMPUTE_FALLBACK_DIVIDEND_YIELD=0.0
GAMMA_COMPUTE_FALLBACK_MIN_DTE_DAYS=1
GAMMA_COMPUTE_FALLBACK_IV_MIN=0.01
GAMMA_COMPUTE_FALLBACK_IV_MAX=5.0
GAMMA_COMPUTE_FALLBACK_MAX_IV_ITERS=80
# IV/RV regime thresholds for iv_rv_state:
# 1 when IV/RV >= high, -1 when IV/RV <= low, else 0
GAMMA_IV_RV_HIGH_RATIO=1.15
GAMMA_IV_RV_LOW_RATIO=0.85
HIST_ACCURACY_MIN_SAMPLE_SIZE=20
BACKFILL_SQLITE_SYNC=FULL
BACKFILL_WAL_AUTOCHECKPOINT=1000
# Optional override list (comma-separated absolute paths):
# ML_REPORT_LOG_FILES=/Users/you/PIVOT_QUANT/logs/retrain.log,/Users/you/PIVOT_QUANT/logs/ml_server.log

# Live collector gamma polling resilience
# Keep gamma snapshot fresh every N seconds when healthy.
LIVE_COLLECTOR_GAMMA_REFRESH_SEC=300
# If gamma bridge is unavailable (e.g., missing IBKR options permissions),
# back off retries to avoid noisy repeated errors.
LIVE_COLLECTOR_GAMMA_RETRY_SEC=1800
# Also score a small backlog slice each collector cycle so backfill-created
# touches do not stay unscored.
LIVE_COLLECTOR_SCORE_UNSCORED_LOOKBACK_DAYS=3
LIVE_COLLECTOR_SCORE_UNSCORED_MAX_PER_CYCLE=12
# Live collector scoring pressure controls.
# Smaller batches + slightly longer request timeout reduce score timeouts
# when ML is under transient load.
LIVE_COLLECTOR_SCORE_BATCH_SIZE=16
LIVE_COLLECTOR_SCORE_TIMEOUT_SEC=12
# Retry transient score transport failures with capped exponential backoff.
LIVE_COLLECTOR_SCORE_MAX_ATTEMPTS=2
LIVE_COLLECTOR_SCORE_RETRY_BASE_SEC=0.5
LIVE_COLLECTOR_SCORE_RETRY_MAX_SEC=4.0
# Circuit-breaker cooldown after HTTP 429 from /score (seconds).
LIVE_COLLECTOR_SCORE_RATE_LIMIT_COOLDOWN_SEC=180
LIVE_COLLECTOR_SQLITE_SYNC=FULL
LIVE_COLLECTOR_WAL_AUTOCHECKPOINT=1000
# Stack supervisor health probe tuning (server/run_all.sh)
# Retries avoid full-stack restarts on short transient ML/collector stalls.
MONITOR_HEALTH_TIMEOUT_SEC=4
MONITOR_HEALTH_RETRIES=3
MONITOR_HEALTH_RETRY_SLEEP_SEC=1
# If true, supervisor exits when event_writer misses hit limit.
# Keep false so short writer hiccups do not restart the whole stack.
MONITOR_EVENT_WRITER_FATAL=false
# ML-specific probe timeout + fail threshold (monitor loop only).
MONITOR_ML_HEALTH_TIMEOUT_SEC=6
MONITOR_ML_CONSECUTIVE_FAIL_LIMIT=6
# If true, supervisor exits when ML health misses hit limit.
# Keep false to avoid full-stack restarts during temporary ML overload.
MONITOR_ML_FATAL=false
# If true, supervisor exits when dashboard misses hit limit.
# Keep false so short dashboard outages do not restart the whole stack.
MONITOR_DASHBOARD_FATAL=false
# Live collector-specific fail threshold (falls back to MONITOR_CONSECUTIVE_FAIL_LIMIT when unset).
MONITOR_LIVE_COLLECTOR_CONSECUTIVE_FAIL_LIMIT=3
# If true, supervisor exits when collector misses hit limit.
# Keep false so collector outages do not restart the whole stack.
MONITOR_LIVE_COLLECTOR_FATAL=false

# Export level-conversion endpoint cache (SPY -> S&P500 / US500)
LEVEL_CONVERTER_SNAPSHOT_TTL_MS=60000
LEVEL_CONVERTER_RESULT_TTL_MS=30000
LEVEL_CONVERTER_CACHE_MAX_SIZE=120

# iMessage (optional, comma-separated recipients)
# ML_REPORT_IMESSAGE_TO=+15551234567
# Optional dedicated alert iMessage recipients
# ML_ALERT_IMESSAGE_TO=+15551234567

# Webhook (optional)
# ML_REPORT_WEBHOOK_URL=https://example.com/webhook
# Optional dedicated alert webhook
# ML_ALERT_WEBHOOK_URL=https://example.com/alert-webhook

# --- Ops resilience: backups / drills / host checks ---
# Backup destination root
PIVOT_BACKUP_ROOT=/Users/tristanalejandro/PIVOT_QUANT/backups
# Shared lock file to prevent overlapping backup/drill runs
PIVOT_OPS_LOCK_FILE=/Users/tristanalejandro/PIVOT_QUANT/logs/ops_resilience.lock
# Wait time before skipping when lock is busy
PIVOT_OPS_LOCK_TIMEOUT_SEC=300
# Retention (effective): newest N daily snapshots + one snapshot per ISO week for W weeks
BACKUP_DAILY_KEEP=30
BACKUP_WEEKLY_KEEP=8
# LaunchAgent schedule (Mac local time)
BACKUP_HOUR=22
BACKUP_MINUTE=20
# Weekly restore drill schedule (weekday: 0=Sunday, 1=Monday, ... 6=Saturday)
RESTORE_DRILL_WEEKDAY=0
RESTORE_DRILL_HOUR=23
RESTORE_DRILL_MINUTE=0
# Host health check cadence (seconds)
HOST_HEALTH_CHECK_INTERVAL_SEC=900
# Host health thresholds
HOST_HEALTH_DISK_WARN_PCT=15
HOST_HEALTH_DISK_CRIT_PCT=8
# Ignore DB growth alerts while DB is still tiny
HOST_HEALTH_DB_GROWTH_MIN_MB=256
HOST_HEALTH_DB_GROWTH_WARN_MB=2048
HOST_HEALTH_DB_GROWTH_CRIT_MB=4096
HOST_HEALTH_RESTART_WARN_DELTA=20
